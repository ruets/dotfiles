#!/bin/bash
# Install user CLI packages through Homebrew.

set -euo pipefail

SCRIPT_RESULT="complete"
trap 'status=$?; if [ "$status" -eq 0 ]; then printf "==> Dotfiles: CLI packages (Homebrew) %s\n" "$SCRIPT_RESULT"; else printf "==> Dotfiles: CLI packages (Homebrew) failed (exit %s)\n" "$status"; fi' EXIT

IS_WINDOWS="{{ .isWindows }}"

printf '\n==> Dotfiles: CLI packages (Homebrew)\n'

if [ "$IS_WINDOWS" == "true" ]; then
  SCRIPT_RESULT="skipped"
  echo "Skipping CLI setup for this host."
  exit 0
fi

CLI_HOMEBREW_PACKAGES=(
{{ range .packages.cli }}  '{{ . }}'
{{ end }})

load_homebrew() {
  if command -v brew >/dev/null 2>&1; then
    return 0
  fi

  for brew_bin in /opt/homebrew/bin/brew /usr/local/bin/brew /home/linuxbrew/.linuxbrew/bin/brew; do
    if [ -x "$brew_bin" ]; then
      eval "$("$brew_bin" shellenv)"
      return 0
    fi
  done

  return 1
}

if ! load_homebrew; then
  printf '  -> Installing Homebrew\n'
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  load_homebrew || {
    echo "Homebrew installed but is not available in PATH yet."
    exit 1
  }
fi

if [ "${#CLI_HOMEBREW_PACKAGES[@]}" -eq 0 ]; then
  SCRIPT_RESULT="skipped"
  echo "No CLI Homebrew packages configured."
  exit 0
fi

if [ ! -f "$HOME/.Brewfile" ]; then
  SCRIPT_RESULT="skipped"
  echo "$HOME/.Brewfile was not generated; skipping Homebrew bundle."
  exit 0
fi

brewfile_fingerprint="$(cksum "$HOME/.Brewfile" | awk '{print $1 "-" $2}')"
brew_bundle_sentinel="${TMPDIR:-/tmp}/dotfiles-brew-bundle-${CHEZMOI_PID:-$PPID}-${brewfile_fingerprint}.done"

if [ -f "$brew_bundle_sentinel" ]; then
  echo "brew bundle --global already ran during this apply."
else
  printf '  -> Running brew bundle --global\n'
  brew bundle --global
  : > "$brew_bundle_sentinel"
fi
