#!/bin/bash
# Install desktop assets that are not package-manager packages.

set -euo pipefail

SCRIPT_RESULT="complete"
trap 'status=$?; if [ "$status" -eq 0 ]; then printf "==> Dotfiles: desktop assets %s\n" "$SCRIPT_RESULT"; else printf "==> Dotfiles: desktop assets failed (exit %s)\n" "$status"; fi' EXIT

IS_LINUX="{{ .isLinux }}"
IS_SERVER="{{ .is_server }}"

printf '\n==> Dotfiles: desktop assets\n'

if [ "$IS_LINUX" != "true" ] || [ "$IS_SERVER" == "true" ]; then
  SCRIPT_RESULT="skipped"
  echo "Skipping desktop assets for this host."
  exit 0
fi

CACHE_DIR="$HOME/.cache/dotfiles"
WALLPAPERS_DIR="$HOME/wallpapers"

printf '  -> Ensuring dotfiles cache directory\n'
mkdir -p "$CACHE_DIR"

if [ -d "$WALLPAPERS_DIR/.git" ]; then
  printf '  -> Updating wallpapers\n'
  git -C "$WALLPAPERS_DIR" pull
else
  printf '  -> Cloning wallpapers\n'
  git clone https://github.com/mylinuxforwork/wallpaper "$WALLPAPERS_DIR"
fi
