#!/bin/bash
# Install backup tooling for server hosts.

set -euo pipefail

SCRIPT_RESULT="complete"
trap 'status=$?; if [ "$status" -eq 0 ]; then printf "==> Dotfiles: server backup tools %s\n" "$SCRIPT_RESULT"; else printf "==> Dotfiles: server backup tools failed (exit %s)\n" "$status"; fi' EXIT

IS_SERVER="{{ .is_server }}"
IS_LINUX="{{ .isLinux }}"
IS_UBUNTU="{{ .isUbuntu }}"

printf '\n==> Dotfiles: server backup tools\n'

if [ "$IS_SERVER" != "true" ] || [ "$IS_LINUX" != "true" ]; then
  SCRIPT_RESULT="skipped"
  echo "Skipping server backup setup for this host."
  exit 0
fi

if [ "$IS_UBUNTU" != "true" ]; then
  SCRIPT_RESULT="skipped"
  echo "Server backup setup is only implemented for Ubuntu Linux right now."
  exit 0
fi

printf '  -> Installing restic\n'
sudo apt update
sudo apt install -y restic

printf '  -> Installing resticprofile\n'
curl -fsSL https://raw.githubusercontent.com/creativeprojects/resticprofile/master/install.sh | sudo sh -s -- -b /usr/local/bin
