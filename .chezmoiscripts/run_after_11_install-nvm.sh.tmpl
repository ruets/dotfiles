#!/bin/bash
# Install nvm (Node Version Manager)

set -e

PNPM_GLOBAL_PACKAGES=(
  # Add pnpm global packages here
)

confirm() {
  if command -v gum >/dev/null 2>&1; then
    gum confirm --default=false "$1"
    return
  fi

  read -r -p "$1 [y/N] " response
  case "$response" in
    [yY]|[yY][eE][sS]) return 0 ;;
    *) return 1 ;;
  esac
}

if ! confirm "Do you want to run the Node/pnpm installation script?"; then
  echo "Skipping Node/pnpm installation."
  exit 0
fi

if [ -d "$HOME/.nvm" ]; then
  echo "nvm already installed, skipping..."
else
  echo "=== Installing nvm ==="
  curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/master/install.sh | bash
fi

# Load nvm for this script only.
\. "$HOME/.nvm/nvm.sh"

echo "Installing Node LTS..."
nvm install --lts
nvm alias default 'lts/*'
nvm use default

export PNPM_HOME="$HOME/.local/share/pnpm"
mkdir -p "$PNPM_HOME"
export PATH="$PNPM_HOME:$PATH"

echo "Installing pnpm..."
corepack enable --install-directory "$PNPM_HOME" pnpm
pnpm config set global-bin-dir "$PNPM_HOME"

if [ ${#PNPM_GLOBAL_PACKAGES[@]} -gt 0 ]; then
  echo "Installing pnpm global packages..."
  pnpm add --global "${PNPM_GLOBAL_PACKAGES[@]}"
fi

echo "=== nvm installation complete ==="
